
@model  List<MVC_ARCHI.Models.student>
@{
    ViewBag.Title = "Student";
}

<h2>liststudent</h2>
<table class="table">
    <tr>
        <th>Student ID</th>
        <th>Name</th>
        <th>Age</th>
        <th>Email</th>
        <th>Enrollment Date</th>
    </tr>
    @foreach (var student in Model)
    {
        <tr>
            <td>@student.studentid</td>
            <td>@student.name</td>
            <td>@student.age</td>
            <td>@student.email</td>
            <td>@student.EnrollmentDate.ToShortDateString()</td>
        </tr>



    }

</table>

